<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GBoxsites - Home</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background-color: #000; color: white; font-family: 'Inter', sans-serif; padding: 20px; padding-bottom: 50px; }
        
        /* Header Section */
        .header { display: flex; justify-content: space-between; align-items: start; margin-bottom: 25px; }
        .logo h1 { font-size: 22px; font-weight: 800; font-style: italic; margin: 0; }
        .logo span { color: #569cd6; font-style: normal; }
        .logo p { font-size: 10px; color: #999; margin-top: 2px; }
        
        .profile-section { display: flex; align-items: center; gap: 10px; text-decoration: none; color: white; }
        .username-top { font-size: 12px; font-weight: bold; }
        .avatar { width: 35px; height: 35px; background: white; border-radius: 50%; color: black; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px; }

        /* VIP Sections */
        .section-label { font-size: 14px; font-weight: bold; margin: 25px 0 12px; text-transform: uppercase; color: #eee; }
        
        /* Grid Layout (3 Kolum) */
        .grid-container { 
            display: grid; 
            grid-template-columns: repeat(3, 1fr); 
            gap: 12px; 
        }

        .poster-box {
            background-color: #1e1e1e; 
            aspect-ratio: 1/1;
            border-radius: 18px; 
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.2s;
            background-size: cover;
            background-position: center;
            border: 1px solid #333;
        }
        .poster-box:active { transform: scale(0.95); }

        /* Wide Slider (VIP Terbaru) */
        .slider-wrapper { position: relative; width: 100%; }
        .slider-container {
            width: 100%;
            height: 180px;
            border-radius: 20px;
            overflow: hidden;
            background-color: #1e1e1e;
            display: flex;
            touch-action: pan-y;
            cursor: grab;
        }
        .slide {
            min-width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            transition: transform 0.5s ease-in-out;
        }

        .dots { 
            display: flex; 
            gap: 6px; 
            position: absolute; 
            bottom: 15px; 
            left: 50%; 
            transform: translateX(-50%); 
            z-index: 10;
        }
        .dot { 
            width: 8px; 
            height: 8px; 
            background: rgba(255,255,255,0.4); 
            border-radius: 50%; 
            transition: all 0.3s;
        }
        .dot.active { 
            background: white; 
            width: 20px; 
            border-radius: 10px; 
        }
    </style>
</head>
<body>

    <div class="header">
        <div class="logo">
            <h1>GBox<span>sites</span></h1>
            <p id="welcomeMsg">Hi, User. Selamat Datang</p>
        </div>
        <a href="pageprofile.html" class="profile-section">
            <span class="username-top" id="topUser">@username</span>
            <div class="avatar" id="topInitial">U</div>
        </a>
    </div>

    <div class="section-label">VIP PREMIUM</div>
    <div class="grid-container">
        <a href="preview1.html" class="poster-box" style="background-image: url('poster1.jpg');"></a>
        <a href="preview2.html" class="poster-box" style="background-image: url('poster2.png');"></a>
        <a href="preview3.html" class="poster-box" style="background-image: url('poster3.png');"></a>
    </div>

    <div class="section-label">VIP POPULAR</div>
    <div class="grid-container">
        <a href="preview4.html" class="poster-box" style="background-image: url('poster4.png');"></a>
        <a href="preview5.html" class="poster-box" style="background-image: url('poster5.png');"></a>
        <a href="preview6.html" class="poster-box" style="background-image: url('poster6.png');"></a>
    </div>

    <div class="section-label">VIP TERBARU</div>
    <div class="slider-wrapper">
        <div class="slider-container" id="slider">
            <div class="slide" style="background-image: url('poster7.png');" onclick="location.href='preview7.html'"></div>
            <div class="slide" style="background-image: url('poster8.png');" onclick="location.href='preview8.html'"></div>
            <div class="slide" style="background-image: url('poster9.png');" onclick="location.href='preview9.html'"></div>
            <div class="slide" style="background-image: url('poster10.png');" onclick="location.href='preview10.html'"></div>
        </div>
        
        <div class="dots">
            <div class="dot active"></div>
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
        </div>
    </div>

    <script>
        // Data User
        const user = localStorage.getItem('currentUser') || "@username001";
        document.getElementById('welcomeMsg').innerText = `Hi, ${user}. Selamat Datang`;
        document.getElementById('topUser').innerText = user;
        document.getElementById('topInitial').innerText = user.charAt(1).toUpperCase();

        // --- Logik Slider (Auto + Manual Swipe) ---
        const slider = document.getElementById('slider');
        const slides = document.querySelectorAll('.slide');
        const dots = document.querySelectorAll('.dot');
        let currentSlide = 0;
        let isDragging = false;
        let startX, currentTranslate, prevTranslate;

        function updateSlider() {
            slides.forEach((s, i) => {
                s.style.transform = `translateX(-${currentSlide * 100}%)`;
            });
            dots.forEach((d, i) => d.classList.toggle('active', i === currentSlide));
        }

        function nextSlide() {
            currentSlide = (currentSlide + 1) % slides.length;
            updateSlider();
        }

        let autoSlideInterval = setInterval(nextSlide, 3000);

        // Fungsi Slide Sendiri (Manual)
        slider.addEventListener('touchstart', (e) => {
            startX = e.touches[0].clientX;
            isDragging = true;
            clearInterval(autoSlideInterval);
        });

        slider.addEventListener('touchend', (e) => {
            if (!isDragging) return;
            const endX = e.changedTouches[0].clientX;
            const diff = startX - endX;

            if (diff > 50) { // Swipe kiri (Next)
                currentSlide = (currentSlide + 1) % slides.length;
            } else if (diff < -50) { // Swipe kanan (Prev)
                currentSlide = (currentSlide - 1 + slides.length) % slides.length;
            }
            
            updateSlider();
            isDragging = false;
            autoSlideInterval = setInterval(nextSlide, 3000); // Sambung auto
        });

        // Security Check
        const db = JSON.parse(localStorage.getItem('gbox_db')) || [];
        const found = db.find(u => u.name === user);
        if (user !== "@admin" && user !== "@haikal") {
            if (!found || found.status !== 'active') window.location.href = "index.html";
        }
    </script>
</body>
</html>
